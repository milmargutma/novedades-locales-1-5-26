rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return false; // Not implemented for now
    }

    function isSignedIn() {
      return true; // Allowing anonymous access since no auth is requested, wait, I will use Google Auth.
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'description', 'author', 'authorUid', 'startDate', 'endDate', 'priority', 'target', 'createdAt', 'status']) &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 10000 &&
             data.author is string && data.author.size() <= 100 &&
             data.authorUid is string && data.authorUid.size() <= 100 &&
             data.startDate is string && data.startDate.size() <= 50 &&
             data.endDate is string && data.endDate.size() <= 50 &&
             data.priority is string && data.priority.matches('^(verde|amarilla|roja)$') &&
             data.target is string && data.target.matches('^(local 4|local 9|administracion|todos)$') &&
             data.status is string && data.status.matches('^(active|archived)$') &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             ( !('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() <= 1500000) ) &&
             ( !('attachmentName' in data) || (data.attachmentName is string && data.attachmentName.size() <= 200) );
    }

    match /news/{newsId} {
      allow read: if true; 
      allow create, update, delete: if isValidId(newsId);
    }
  }
}
